# S.H.I.E.L.D — Environment Configuration
# Copy this file to .env and update the values
# ═══════════════════════════════════════════════════════

# MongoDB
MONGO_USER=shield_admin
MONGO_PASS=ShieldMongo2024Secure!
MONGO_URI=mongodb://shield_admin:ShieldMongo2024Secure!@mongodb:27017/shield?authSource=admin

# Redis
REDIS_PASS=ShieldRedis2024Secure!
REDIS_URL=redis://:ShieldRedis2024Secure!@redis:6379

# JWT
JWT_SECRET=shield-jwt-s3cr3t-k3y-2024-ultra-s3cure-hackathon-edition
JWT_EXPIRES_IN=15m
JWT_REFRESH_SECRET=shield-refresh-s3cr3t-k3y-2024-ultra-s3cure
JWT_REFRESH_EXPIRES_IN=7d

# Backend
NODE_ENV=development
PORT=3000
CORS_ORIGIN=http://localhost:5173

# AI Service
AI_SERVICE_URL=http://ai-service:8000

# Digital Twin
DIGITAL_TWIN_URL=http://digital-twin:3002
BACKEND_URL=http://backend:3000

# MFA
MFA_ISSUER=SHIELD-SmartCity

# Rate Limiting
RATE_LIMIT_WINDOW_MS=60000
RATE_LIMIT_MAX=60
AUTH_RATE_LIMIT_MAX=10
